{
  "rules": {
    "codes": {
      // Anyone authenticated (anonymously) can read codes to validate their login
      ".read": "auth != null",
      // Only the admin code can write new codes — enforced server-side via admin SDK
      // For client-side Firebase, we lock down writes here; use Firebase Admin SDK or
      // a Cloud Function with the admin code verification to generate codes instead.
      // As a simpler alternative: allow write only if the data is a new code being created
      // and the request includes a valid admin secret (handled via separate admin endpoint).
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && !data.exists()"
      }
    },
    "progress": {
      "$uid": {
        // Users can only read and write their own progress
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$lessonId": {
          "$stepId": {
            // Only allow valid fields
            ".validate": "newData.hasChildren(['startedAt']) || newData.hasChildren(['completed']) || newData.hasChildren(['totalMs'])"
          }
        }
      },
      // Admin read: handled by a separate admin account, not anonymous
      // If using a dedicated admin UID, add: || auth.uid === 'YOUR_ADMIN_UID'
    }
  }
}
